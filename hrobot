# ─── SSH Key Commands ────────────────────────────────────────────────

cmd_keys() {
  need_auth
  local data
  data=$(api GET /key)
  echo "$data" | table "SSH KEYS" "NAME\tFINGERPRINT\tTYPE\tSIZE" \
    '.[] | .key | [.name, .fingerprint, .type, .size] | @tsv'
}

cmd_key() {
  local action="${1:-list}"
  need_auth

  case "$action" in
    list)
      cmd_keys
      ;;
    add)
      local name="${2:-}" keyfile="${3:-}"
      [ -n "$name" ] && [ -n "$keyfile" ] || die "Usage: hrobot key add <name> <key-file-or-string>"
      local keydata
      if [ -f "$keyfile" ]; then
        keydata=$(cat "$keyfile")
      else
        keydata="$keyfile"
      fi
      api POST /key -d "name=$name" --data-urlencode "data=$keydata" | fmt
      info "✓ SSH key '$name' added"
      ;;
    del)
      local fp="${2:-}" ; [ -n "$fp" ] || die "Usage: hrobot key del <fingerprint>"
      api DELETE "/key/$fp" | fmt
      info "✓ SSH key removed"
      ;;
    *)
      die "Usage: hrobot key [list|add|del] [args...]"
      ;;
  esac
}

# ─── Traffic Commands ────────────────────────────────────────────────

cmd_traffic() {
  local num="${1:-}" period="${2:-monthly}"
  [ -n "$num" ] || die "Usage: hrobot traffic <server-number> [daily|monthly|yearly]"
  need_auth

  local from to type
  case "$period" in
    daily)   from=$(date +%Y-%m-%dT00); to=$(date +%Y-%m-%dT%H); type="day" ;;
    monthly) from=$(date +%Y-%m-01); to=$(date +%Y-%m-%d); type="month" ;;
    yearly)  from=$(date +%Y-01); to=$(date +%Y-%m); type="year" ;;
    *)       die "Period must be: daily, monthly, or yearly" ;;
  esac

  local server_ip
  server_ip=$(api GET "/server/$num" | jq -r '.server.server_ip')

  api POST /traffic \
    --data-urlencode "ip=$server_ip" \
    --data-urlencode "from=$from" \
    --data-urlencode "to=$to" \
    --data-urlencode "type=$type" | fmt
}

