# ─── Reverse DNS Commands ────────────────────────────────────────────

cmd_rdns() {
  local action="${1:-list}"
  need_auth

  case "$action" in
    list)
      local data
      data=$(api GET /rdns)
      echo "$data" | table "REVERSE DNS" "IP\tPTR" \
        '.[] | .rdns | [.ip, .ptr] | @tsv'
      ;;
    get)
      local ip="${2:-}" ; [ -n "$ip" ] || die "Usage: hrobot rdns get <ip>"
      api GET "/rdns/$ip" | jq '.rdns'
      ;;
    set)
      local ip="${2:-}" ptr="${3:-}"
      [ -n "$ip" ] && [ -n "$ptr" ] || die "Usage: hrobot rdns set <ip> <ptr-record>"
      api POST "/rdns/$ip" -d "ptr=$ptr" | fmt
      info "✓ PTR record set: $ip → $ptr"
      ;;
    del)
      local ip="${2:-}" ; [ -n "$ip" ] || die "Usage: hrobot rdns del <ip>"
      api DELETE "/rdns/$ip" | fmt
      info "✓ PTR record removed for $ip"
      ;;
    *)
      die "Usage: hrobot rdns [list|get|set|del] [args...]"
      ;;
  esac
}

