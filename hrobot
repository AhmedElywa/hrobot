# в”Ђв”Ђв”Ђ SSH Key Commands в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

cmd_keys() {
  need_auth
  api GET /key | table "SSH KEYS" \
    '.[] | .key | [.name, .fingerprint, .type, .size] | @tsv' |
    (echo -e "NAME\tFINGERPRINT\tTYPE\tSIZE" && cat) | column -t -s $'\t'
}

cmd_key() {
  local action="${1:-list}"
  need_auth

  case "$action" in
    list)
      cmd_keys
      ;;
    add)
      local name="${2:-}" keyfile="${3:-}"
      [ -n "$name" ] && [ -n "$keyfile" ] || die "Usage: hrobot key add <name> <key-file-or-string>"
      local keydata
      if [ -f "$keyfile" ]; then
        keydata=$(cat "$keyfile")
      else
        keydata="$keyfile"
      fi
      api POST /key -d "name=$name" --data-urlencode "data=$keydata" | fmt
      info "вњ“ SSH key '$name' added"
      ;;
    del)
      local fp="${2:-}" ; [ -n "$fp" ] || die "Usage: hrobot key del <fingerprint>"
      api DELETE "/key/$fp" | fmt
      info "вњ“ SSH key removed"
      ;;
    *)
      die "Usage: hrobot key [list|add|del] [args...]"
      ;;
  esac
}

# в”Ђв”Ђв”Ђ Traffic Commands в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

cmd_traffic() {
  local num="${1:-}" period="${2:-monthly}"
  [ -n "$num" ] || die "Usage: hrobot traffic <server-number> [daily|monthly|yearly]"
  need_auth

  local from to type
  case "$period" in
    daily)   from=$(date -d "1 day ago" +%Y-%m-%dT00:00:00+00:00); to=$(date +%Y-%m-%dT23:59:59+00:00); type="day" ;;
    monthly) from=$(date +%Y-%m-01T00:00:00+00:00); to=$(date +%Y-%m-%dT23:59:59+00:00); type="month" ;;
    yearly)  from=$(date +%Y-01-01T00:00:00+00:00); to=$(date +%Y-%m-%dT23:59:59+00:00); type="year" ;;
    *)       die "Period must be: daily, monthly, or yearly" ;;
  esac

  api POST /traffic \
    -d "ip[]=$(api GET "/server/$num" | jq -r '.server.server_ip')" \
    -d "from=$from" \
    -d "to=$to" \
    -d "type=$type" | fmt
}

