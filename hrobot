# в”Ђв”Ђв”Ђ Cancellation Commands в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

cmd_cancel() {
  local num="${1:-}" ; [ -n "$num" ] || die "Usage: hrobot cancel <server-number>"
  need_auth

  warn "вљ  This will cancel server $num!"
  read -rp "Type the server number to confirm: " confirm
  [ "$confirm" = "$num" ] || { echo "Cancelled."; return; }

  # Get cancellation options first
  local options
  options=$(api GET "/server/$num/cancellation")
  local earliest
  earliest=$(echo "$options" | jq -r '.cancellation.earliest_cancellation_date')

  api POST "/server/$num/cancellation" -d "cancellation_date=$earliest" | fmt
  info "вњ“ Server $num cancelled (effective: $earliest)"
}

# в”Ђв”Ђв”Ђ Order Commands в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

cmd_order() {
  local action="${1:-products}"
  need_auth

  case "$action" in
    products|list)
      api GET /order/server/product | table "AVAILABLE SERVERS" \
        '.[] | .product | [.id, .name, (.price | tostring) + " " + .price_setup_recurring, .cpu, .memory, (.hdd_text // .description)] | @tsv' |
        (echo -e "ID\tNAME\tPRICE\tCPU\tRAM\tDISK" && cat) | column -t -s $'\t'
      ;;
    market)
      api GET /order/server_market/product | fmt
      ;;
    transactions)
      api GET /order/server/transaction | fmt
      ;;
    product)
      local id="${2:-}" ; [ -n "$id" ] || die "Usage: hrobot order product <product-id>"
      api GET "/order/server/product/$id" | fmt
      ;;
    *)
      die "Usage: hrobot order [products|market|transactions|product <id>]"
      ;;
  esac
}

# в”Ђв”Ђв”Ђ vSwitch Commands в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

cmd_vswitch() {
  local action="${1:-list}"
  need_auth

  case "$action" in
    list)
      api GET /vswitch | fmt
      ;;
    get)
      local id="${2:-}" ; [ -n "$id" ] || die "Usage: hrobot vswitch get <id>"
      api GET "/vswitch/$id" | fmt
      ;;
    create)
      local name="${2:-}" vlan="${3:-}"
      [ -n "$name" ] && [ -n "$vlan" ] || die "Usage: hrobot vswitch create <name> <vlan-id>"
      api POST /vswitch -d "name=$name" -d "vlan=$vlan" | fmt
      info "вњ“ vSwitch '$name' created"
      ;;
    del)
      local id="${2:-}" ; [ -n "$id" ] || die "Usage: hrobot vswitch del <id>"
      api DELETE "/vswitch/$id" | fmt
      info "вњ“ vSwitch $id deleted"
      ;;
    *)
      die "Usage: hrobot vswitch [list|get|create|del] [args...]"
      ;;
  esac
}

# в”Ђв”Ђв”Ђ Failover Commands в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

cmd_failover() {
  local action="${1:-list}"
  need_auth

  case "$action" in
    list)
      api GET /failover | fmt
      ;;
    get)
      local ip="${2:-}" ; [ -n "$ip" ] || die "Usage: hrobot failover get <ip>"
      api GET "/failover/$ip" | fmt
      ;;
    switch)
      local ip="${2:-}" target="${3:-}"
      [ -n "$ip" ] && [ -n "$target" ] || die "Usage: hrobot failover switch <failover-ip> <target-server-ip>"
      api POST "/failover/$ip" -d "active_server_ip=$target" | fmt
      info "вњ“ Failover $ip routed to $target"
      ;;
    *)
      die "Usage: hrobot failover [list|get|switch] [args...]"
      ;;
  esac
}

# в”Ђв”Ђв”Ђ Main в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

usage() {
  cat << 'EOF'
hrobot вЂ” CLI for Hetzner Robot API (dedicated servers)

USAGE
  hrobot <command> [args...]

AUTH
  auth               Authenticate with Hetzner Robot API
  status             Check authentication and API connection

SERVERS
  servers            List all servers
  server <num>       Show server details
  rename <num> <n>   Rename a server
  reset <num> [type] Reset server (sw=software, hw=hardware, man=manual)
  wol <num>          Send Wake-on-LAN packet
  cancel <num>       Cancel a server (with confirmation)
  boot <num>         Show boot configuration
  rescue <num> [..] Manage rescue mode (status|activate|deactivate|last)

NETWORK
  ips                List all IP addresses
  ip <addr>          Show IP details
  subnets            List all subnets
  rdns [action]      Manage reverse DNS (list|get|set|del)
  firewall <num>     Show/manage firewall (status|disable)
  failover [action]  Manage failover IPs (list|get|switch)
  vswitch [action]   Manage vSwitches (list|get|create|del)
  traffic <num> [p]  Show traffic stats (daily|monthly|yearly)

SSH KEYS
  keys               List SSH keys
  key [action]       Manage keys (list|add|del)

STORAGE
  storageboxes       List storage boxes
  storagebox <id>    Show storage box details

ORDERING
  order [action]     Browse/order servers (products|market|product <id>)

OPTIONS
  -h, --help         Show this help
  -v, --version      Show version

ENVIRONMENT
  HROBOT_CONFIG_DIR  Config directory (default: ~/.config/hrobot)
EOF
}

main() {
  need_cmd curl
  need_cmd jq

  local cmd="${1:-help}"
  shift 2>/dev/null || true

  case "$cmd" in
    auth)           cmd_auth "$@" ;;
    status)         cmd_status "$@" ;;
    servers|ls)     cmd_servers "$@" ;;
    server)         cmd_server "$@" ;;
    rename)         cmd_server_rename "$@" ;;
    reset)          cmd_reset "$@" ;;
    rescue)         cmd_rescue "$@" ;;
    boot)           cmd_boot "$@" ;;
    wol)            cmd_wol "$@" ;;
    cancel)         cmd_cancel "$@" ;;
    ips)            cmd_ips "$@" ;;
    ip)             cmd_ip "$@" ;;
    subnets)        cmd_subnets "$@" ;;
    rdns)           cmd_rdns "$@" ;;
    firewall|fw)    cmd_firewall "$@" ;;
    failover|fo)    cmd_failover "$@" ;;
    vswitch|vs)     cmd_vswitch "$@" ;;
    traffic)        cmd_traffic "$@" ;;
    keys)           cmd_keys "$@" ;;
    key)            cmd_key "$@" ;;
    storageboxes)   cmd_storageboxes "$@" ;;
    storagebox)     cmd_storagebox "$@" ;;
    order)          cmd_order "$@" ;;
    -v|--version|version) echo "hrobot $VERSION" ;;
    -h|--help|help) usage ;;
    *)              die "Unknown command: $cmd. Run 'hrobot help' for usage." ;;
  esac
}

main "$@"
