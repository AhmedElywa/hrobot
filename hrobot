# в”Ђв”Ђв”Ђ Reverse DNS Commands в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

cmd_rdns() {
  local action="${1:-list}"
  need_auth

  case "$action" in
    list)
      api GET /rdns | table "REVERSE DNS" \
        '.[] | .rdns | [.ip, .ptr] | @tsv' |
        (echo -e "IP\tPTR" && cat) | column -t -s $'\t'
      ;;
    get)
      local ip="${2:-}" ; [ -n "$ip" ] || die "Usage: hrobot rdns get <ip>"
      api GET "/rdns/$ip" | jq '.rdns'
      ;;
    set)
      local ip="${2:-}" ptr="${3:-}"
      [ -n "$ip" ] && [ -n "$ptr" ] || die "Usage: hrobot rdns set <ip> <ptr-record>"
      api POST "/rdns/$ip" -d "ptr=$ptr" | fmt
      info "вњ“ PTR record set: $ip в†’ $ptr"
      ;;
    del)
      local ip="${2:-}" ; [ -n "$ip" ] || die "Usage: hrobot rdns del <ip>"
      api DELETE "/rdns/$ip" | fmt
      info "вњ“ PTR record removed for $ip"
      ;;
    *)
      die "Usage: hrobot rdns [list|get|set|del] [args...]"
      ;;
  esac
}

