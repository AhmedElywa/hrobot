# ─── Cancellation Commands ────────────────────────────────────────────

cmd_cancel() {
  local num="${1:-}" ; [ -n "$num" ] || die "Usage: hrobot cancel <server-number>"
  need_auth

  warn "⚠ This will cancel server $num!"
  read -rp "Type the server number to confirm: " confirm
  [ "$confirm" = "$num" ] || { echo "Cancelled."; return; }

  # Get cancellation options first
  local options
  options=$(api GET "/server/$num/cancellation")
  local earliest
  earliest=$(echo "$options" | jq -r '.cancellation.earliest_cancellation_date')

  api POST "/server/$num/cancellation" -d "cancellation_date=$earliest" | fmt
  info "✓ Server $num cancelled (effective: $earliest)"
}

# ─── Order Commands ───────────────────────────────────────────────────

SB_FEED="https://www.hetzner.com/_resources/app/data/app/live_data_sb_EUR.json"
CATALOG_FEED="https://www.hetzner.com/_resources/app/data/app/live_data_en_EUR.json"

_sb_fetch() {
  local data
  data=$(curl -s "$SB_FEED") || die "Failed to fetch server market data"
  [ -n "$data" ] && echo "$data" | jq -e '.server' >/dev/null 2>&1 || die "Invalid response from server market"
  echo "$data"
}

_catalog_fetch() {
  local data
  data=$(curl -s "$CATALOG_FEED") || die "Failed to fetch server catalog"
  [ -n "$data" ] && echo "$data" | jq -e '.server' >/dev/null 2>&1 || die "Invalid response from server catalog"
  echo "$data"
}

cmd_market() {
  # Parse flags
  local min_ram=0 max_price=999999 dc_filter="" cpu_filter="" disk_filter="" ecc_only=false sort_by="price"
  local -a args=()
  while [ $# -gt 0 ]; do
    case "$1" in
      --ram)      min_ram="${2:-0}" ; shift 2 ;;
      --price)    max_price="${2:-999999}" ; shift 2 ;;
      --dc)       dc_filter="${2:-}" ; shift 2 ;;
      --cpu)      cpu_filter="${2:-}" ; shift 2 ;;
      --nvme)     disk_filter="nvme" ; shift ;;
      --ssd)      disk_filter="ssd" ; shift ;;
      --hdd)      disk_filter="hdd" ; shift ;;
      --ecc)      ecc_only=true ; shift ;;
      --sort)     sort_by="${2:-price}" ; shift 2 ;;
      -*)         die "Unknown flag: $1. Filters: --ram N --price N --dc X --cpu X --nvme --ssd --hdd --ecc --sort price|ram|disk|drop" ;;
      *)          args+=("$1") ; shift ;;
    esac
  done

  local action="${args[0]:-list}"

  case "$action" in
    list|ls)
      local data
      data=$(_sb_fetch)
      # Filter and sort
      local filtered
      filtered=$(echo "$data" | jq \
        --argjson min_ram "$min_ram" \
        --argjson max_price "$max_price" \
        --arg dc "$dc_filter" \
        --arg cpu "$cpu_filter" \
        --arg disk "$disk_filter" \
        --arg ecc "$ecc_only" \
        --arg sort "$sort_by" \
        '[.server[]
          | select(.ram_size >= $min_ram)
          | select(.price <= $max_price)
          | select(if $dc != "" then (.datacenter | ascii_downcase | contains($dc | ascii_downcase)) else true end)
          | select(if $cpu != "" then (.cpu | ascii_downcase | contains($cpu | ascii_downcase)) else true end)
          | select(if $disk == "nvme" then (.serverDiskData.nvme | length) > 0
                   elif $disk == "ssd" then (.serverDiskData.sata | length) > 0
                   elif $disk == "hdd" then (.serverDiskData.hdd | length) > 0
                   else true end)
          | select(if $ecc == "true" then .is_ecc else true end)
        ] | sort_by(
          if $sort == "ram" then .ram_size
          elif $sort == "disk" then .hdd_size
          elif $sort == "drop" then (if .fixed_price then 999999 else .next_reduce end)
          else .price end
        )')
      local count
      count=$(echo "$filtered" | jq 'length')
      echo "$filtered" | table "SERVER AUCTION ($count servers)" \
        "PRICE\tID\tCPU\tRAM\tDISK\tDC\tNEXT DROP" \
        'def fmt_disk:
           def disk_type:
             if (.serverDiskData.nvme | length) > 0 and (.serverDiskData.sata | length) > 0 then "NVMe+SSD"
             elif (.serverDiskData.nvme | length) > 0 then "NVMe"
             elif (.serverDiskData.hdd | length) > 0 and (.serverDiskData.sata | length) > 0 then "HDD+SSD"
             elif (.serverDiskData.hdd | length) > 0 then "HDD"
             elif (.hdd_arr | length) > 0 then (.hdd_arr[0] | split("TB ") | last | split("GB ") | last)
             else "HDD" end;
           (.hdd_count | tostring) + "x " +
           (if .hdd_size >= 1024 then ((.hdd_size / 1024 * 10 | floor / 10) | tostring) + "TB"
            else (.hdd_size | tostring) + "GB" end) + " " + disk_type;
         def fmt_reduce:
           if .next_reduce > 3600 then
             ((.next_reduce / 3600 | floor) | tostring) + "h " + ((.next_reduce % 3600 / 60 | floor) | tostring) + "m"
           elif .next_reduce > 0 then
             ((.next_reduce / 60 | floor) | tostring) + "m"
           else "-" end;
         .[]
         | [
             (.price | tostring) + "€",
             .id,
             .cpu,
             (.ram_size | tostring) + "GB",
             fmt_disk,
             .datacenter,
             (if .fixed_price then "fixed" else fmt_reduce end)
           ] | @tsv'
      ;;
    show|info)
      local id="${args[1]:-}" ; [ -n "$id" ] || die "Usage: hrobot market show <product-id>"
      local data
      data=$(_sb_fetch)
      local server
      server=$(echo "$data" | jq --argjson id "$id" '.server[] | select(.id == $id)')
      [ -n "$server" ] || die "Server $id not found in market"
      _market_detail "$server"
      ;;
    buy|order)
      local id="${args[1]:-}" ; [ -n "$id" ] || die "Usage: hrobot market buy <product-id>"
      _market_buy "$id"
      ;;
    transactions|tx)
      need_auth
      local data
      data=$(api GET /order/server_market/transaction)
      echo "$data" | table "MARKET TRANSACTIONS" "ID\tDATE\tSTATUS\tSERVER\tPRODUCT" \
        '.[] | .transaction | [.id, (.date | split("T") | first), .status, (.server_number // "-"), (.product.cpu // "-")] | @tsv'
      ;;
    *)
      die "Unknown: $action. Usage: hrobot market [list|show <id>|buy <id>|tx] [--ram N --price N --dc X --cpu X --nvme --ssd --hdd --ecc --sort price|ram|disk|drop]"
      ;;
  esac
}

_market_detail() {
  local p="$1"

  local id cpu ram ram_hr dc price hourly setup bw ecc specials reduce fixed
  id=$(echo "$p" | jq -r '.id')
  cpu=$(echo "$p" | jq -r '(.cpu_count | tostring) + "x " + .cpu')
  ram=$(echo "$p" | jq -r '.ram_size')
  ram_hr=$(echo "$p" | jq -r '.ram | join(", ")')
  dc=$(echo "$p" | jq -r '.datacenter')
  price=$(echo "$p" | jq -r '.price')
  hourly=$(echo "$p" | jq -r '.hourly_price')
  setup=$(echo "$p" | jq -r '.setup_price')
  bw=$(echo "$p" | jq -r '.bandwidth')
  ecc=$(echo "$p" | jq -r 'if .is_ecc then "yes" else "no" end')
  specials=$(echo "$p" | jq -r 'if (.specials | length) > 0 then .specials | join(", ") else "(none)" end')
  fixed=$(echo "$p" | jq -r '.fixed_price')
  reduce=$(echo "$p" | jq -r '
    if .fixed_price then "fixed"
    elif .next_reduce > 3600 then ((.next_reduce / 3600 | floor) | tostring) + "h " + ((.next_reduce % 3600 / 60 | floor) | tostring) + "m"
    elif .next_reduce > 0 then ((.next_reduce / 60 | floor) | tostring) + "m"
    else "-" end')

  if [ -t 1 ]; then
    echo ""
    echo -e "  ${BOLD}SERVER #${id}${NC}"
    echo ""
    echo -e "  ${DIM}CPU${NC}         $cpu"
    echo -e "  ${DIM}RAM${NC}         ${ram}GB ${DIM}($ram_hr)${NC}"
    echo -e "  ${DIM}Disk${NC}"
    echo "$p" | jq -r '.hdd_hr[]' | while IFS= read -r line; do echo "              $line"; done
    echo -e "  ${DIM}Network${NC}     ${bw} Mbit/s"
    echo -e "  ${DIM}Location${NC}    $dc"
    echo -e "  ${DIM}ECC${NC}         $ecc"
    echo -e "  ${DIM}Features${NC}    $specials"
    echo ""
    echo -e "  ${DIM}Price${NC}       ${BOLD}${price}€/mo${NC}  ${DIM}(${hourly}€/hr, setup: ${setup}€)${NC}"
    if [ "$fixed" = "false" ]; then
      echo -e "  ${DIM}Next drop${NC}   ${YELLOW}${reduce}${NC}"
    else
      echo -e "  ${DIM}Type${NC}        Fixed price"
    fi
    echo ""
  else
    echo "$p" | jq .
  fi
}

_market_buy() {
  local id="$1"

  # Show product from public feed first
  local sb_data server
  sb_data=$(_sb_fetch)
  server=$(echo "$sb_data" | jq --argjson id "$id" '.server[] | select(.id == $id)')
  [ -n "$server" ] || die "Server $id not found in market"
  _market_detail "$server"

  local price
  price=$(echo "$server" | jq -r '.price')

  # Auth needed for ordering
  need_auth

  # Select SSH keys
  _select_keys

  # Final confirmation
  echo ""
  warn "  ⚠ This will order a server for ${price}€/month"
  echo ""
  read -rp "  Type 'YES' to confirm the order: " confirm
  [ "$confirm" = "YES" ] || { echo "  Cancelled."; return; }

  # Place the order
  local -a curl_args=()
  curl_args+=(-d "product_id=$id")
  for fp in "${_SELECTED_KEYS[@]}"; do
    curl_args+=(--data-urlencode "authorized_key[]=$fp")
  done

  echo ""
  echo -n "  Placing order... "
  local result
  result=$(api POST /order/server_market/transaction "${curl_args[@]}")

  local txn_id txn_status
  txn_id=$(echo "$result" | jq -r '.transaction.id')
  txn_status=$(echo "$result" | jq -r '.transaction.status')

  info "✓ Done!"
  echo ""
  echo -e "  ${BOLD}Order Placed${NC}"
  echo -e "  ${DIM}Transaction${NC}  $txn_id"
  echo -e "  ${DIM}Status${NC}       $txn_status"
  echo ""
  dim "  Track with: hrobot market transactions"
  echo ""
}

# ─── Shared: SSH Key Selection ───────────────────────────────────────
# Sets _SELECTED_KEYS array with chosen fingerprints

_select_keys() {
  local keys_data
  keys_data=$(api GET /key)
  local key_count
  key_count=$(echo "$keys_data" | jq 'length')

  [ "$key_count" -gt 0 ] || die "No SSH keys found. Add one first: hrobot key add <name> <key-file>"

  echo -e "  ${BOLD}SSH Keys${NC}"
  echo ""
  local i=1
  while IFS=$'\t' read -r name fp; do
    echo -e "    ${GREEN}${i})${NC} ${name} ${DIM}(${fp})${NC}"
    i=$((i + 1))
  done < <(echo "$keys_data" | jq -r '.[] | .key | [.name, .fingerprint] | @tsv')
  echo ""

  local selection
  if [ "$key_count" -eq 1 ]; then
    selection="1"
    echo -e "  ${DIM}Using your only SSH key.${NC}"
  else
    read -rp "  Select key(s) [1-${key_count}, comma-separated, or 'all']: " selection
    [ -n "$selection" ] || { echo "  Cancelled."; exit 0; }
  fi

  _SELECTED_KEYS=()
  if [ "$selection" = "all" ]; then
    while IFS= read -r fp; do
      _SELECTED_KEYS+=("$fp")
    done < <(echo "$keys_data" | jq -r '.[] | .key | .fingerprint')
  else
    IFS=',' read -ra indices <<< "$selection"
    local all_fps
    all_fps=$(echo "$keys_data" | jq -r '.[] | .key | .fingerprint')
    for idx in "${indices[@]}"; do
      idx=$(echo "$idx" | tr -d ' ')
      local fp
      fp=$(echo "$all_fps" | sed -n "${idx}p")
      [ -n "$fp" ] || die "Invalid key number: $idx"
      _SELECTED_KEYS+=("$fp")
    done
  fi
}

# ─── Catalog (New Servers) ───────────────────────────────────────────

cmd_catalog() {
  local sort_by="price"
  local -a args=()
  while [ $# -gt 0 ]; do
    case "$1" in
      --sort)  sort_by="${2:-price}" ; shift 2 ;;
      -*)      die "Unknown flag: $1. Options: --sort price|ram|name" ;;
      *)       args+=("$1") ; shift ;;
    esac
  done

  local action="${args[0]:-list}"

  case "$action" in
    list|ls)
      local data
      data=$(_catalog_fetch)
      echo "$data" | jq --arg sort "$sort_by" '.server' | table "DEDICATED SERVERS" \
        "FROM\tSETUP\tNAME\tCPU\tRAM\tDISK\tDC" \
        'def short_disk: gsub("Datacenter Edition "; "DC ") | gsub("Datacenter Edition"; "DC") | gsub(" \\(Gen4\\)"; "") | gsub(" \\(Gen 4\\)"; "") | gsub(" \\(Gen3\\)"; "") | gsub(" \\(Gen 3\\)"; "");
         def short_cpu: gsub("™"; "") | gsub("®"; "") | gsub(" Prozessor"; "");
         [.[] | select(.category != "Upfront")]
         | sort_by(if $ARGS.named.sort == "ram" then .ram elif $ARGS.named.sort == "name" then .name else .price end)[]
         | [
             (.price | tostring) + "€",
             (if .setup_price == 0 then "free" else (.setup_price | tostring) + "€" end),
             .name,
             (.cpu | short_cpu),
             (.ram | tostring) + "GB",
             ((.hdd_count | tostring) + "x " + (.hdd_arr | first // "-" | short_disk)),
             ([.datacenter[].shortname] | join(","))
           ] | @tsv'
      ;;
    show|info)
      local id="${args[1]:-}" ; [ -n "$id" ] || die "Usage: hrobot catalog show <name>"
      local data
      data=$(_catalog_fetch)
      _catalog_detail "$data" "$id"
      ;;
    buy|order)
      local id="${args[1]:-}" ; [ -n "$id" ] || die "Usage: hrobot catalog buy <product-id>"
      _catalog_buy "$id"
      ;;
    *)
      die "Usage: hrobot catalog [list|show <name>|buy <id>]"
      ;;
  esac
}

_catalog_detail() {
  local data="$1"
  local name="$2"

  # Find all variants matching this name (case-insensitive)
  local variants
  variants=$(echo "$data" | jq --arg n "$name" '[.server[] | select(.name | ascii_downcase == ($n | ascii_downcase))]')
  local count
  count=$(echo "$variants" | jq 'length')
  [ "$count" -gt 0 ] || die "Server '$name' not found. Run: hrobot catalog"

  # Use the configurable (non-Upfront) variant for base info, fall back to first
  local base
  base=$(echo "$variants" | jq '[.[] | select(.category != "Upfront")] | first // .[0]')

  local cpu ram_hr is_ecc bw
  cpu=$(echo "$base" | jq -r '.cpu')
  ram_hr=$(echo "$base" | jq -r '.ram_hr // ((.ram | tostring) + " GB")')
  is_ecc=$(echo "$base" | jq -r 'if .is_ecc then "yes" else "no" end')
  bw=$(echo "$base" | jq -r '.Bandwidth // .bandwidth // 1000')

  local disks_hr
  disks_hr=$(echo "$base" | jq -r 'if (.hdd_hr | type) == "string" then .hdd_hr | gsub("\\\\r\\\\n"; "\n") else (.hdd_hr // .hdd_arr // []) | join("\n") end')

  # Collect unique locations with pricing from Upfront variants
  local pricing
  pricing=$(echo "$variants" | jq -r '
    [.[] | select(.category == "Upfront") | {
      dc: ([.datacenter[].shortname] | join(",")),
      price: .price,
      setup: .setup_price,
      hourly: .hourPrice
    }] | sort_by(.price) | unique_by(.dc)[]
    | "    " + .dc + "\t" + (.price | tostring) + "€/mo\t(" + (.hourly | tostring) + "€/hr, setup: " + (if .setup == 0 then "free" else (.setup | tostring) + "€" end) + ")"')

  # If no Upfront variants, show from configurable
  if [ -z "$pricing" ]; then
    pricing=$(echo "$base" | jq -r '
      ([.datacenter[].shortname] | join(",")) as $dc
      | "    " + $dc + "\t" + (.price | tostring) + "€/mo\t(setup: " + (if .setup_price == 0 then "free" else (.setup_price | tostring) + "€" end) + ")"')
  fi

  local specials
  specials=$(echo "$base" | jq -r 'if (.specials // [] | length) > 0 then .specials | join(", ") else "(none)" end')

  if [ -t 1 ]; then
    echo ""
    echo -e "  ${BOLD}${name}${NC}"
    echo ""
    echo -e "  ${DIM}CPU${NC}         $cpu"
    echo -e "  ${DIM}RAM${NC}         $ram_hr"
    echo -e "  ${DIM}Disk${NC}"
    echo "$disks_hr" | while IFS= read -r line; do echo "              $line"; done
    echo -e "  ${DIM}Network${NC}     ${bw} Mbit/s"
    echo -e "  ${DIM}ECC${NC}         $is_ecc"
    echo -e "  ${DIM}Features${NC}    $specials"
    echo ""
    echo -e "  ${DIM}Pricing${NC}"
    echo "$pricing" | while IFS= read -r line; do echo -e "$line"; done | column -t -s $'\t'
    echo ""
  else
    echo "$base" | jq .
  fi
}

_catalog_buy() {
  local id="$1"
  need_auth

  # Fetch product details
  local product
  product=$(api GET "/order/server/product/$id")
  _catalog_detail "$product"

  local p
  p=$(echo "$product" | jq '.product')

  # Location selection
  local -a locs
  mapfile -t locs < <(echo "$p" | jq -r '.location[]')
  local location

  if [ "${#locs[@]}" -eq 1 ]; then
    location="${locs[0]}"
    echo -e "  ${DIM}Location: ${location}${NC}"
  else
    echo -e "  ${BOLD}Location${NC}"
    echo ""
    local i=1
    for loc in "${locs[@]}"; do
      local loc_price
      loc_price=$(echo "$p" | jq -r --arg loc "$loc" '.prices[] | select(.location == $loc) | (.price.net | rtrimstr("00") | rtrimstr("0")) + "€/mo"')
      echo -e "    ${GREEN}${i})${NC} ${loc} ${DIM}(${loc_price})${NC}"
      i=$((i + 1))
    done
    echo ""
    read -rp "  Select location [1-${#locs[@]}]: " loc_idx
    [ -n "$loc_idx" ] || { echo "  Cancelled."; return; }
    location="${locs[$((loc_idx - 1))]}"
    [ -n "$location" ] || die "Invalid location"
  fi

  local price setup
  price=$(echo "$p" | jq -r --arg loc "$location" '.prices[] | select(.location == $loc) | .price.net | rtrimstr("00") | rtrimstr("0")')
  setup=$(echo "$p" | jq -r --arg loc "$location" '.prices[] | select(.location == $loc) | .price_setup.net | rtrimstr("00") | rtrimstr("0")')

  # SSH key selection
  echo ""
  _select_keys

  # Final confirmation
  echo ""
  warn "  ⚠ This will order ${id} in ${location} for ${price}€/month (setup: ${setup}€)"
  echo ""
  read -rp "  Type 'YES' to confirm the order: " confirm
  [ "$confirm" = "YES" ] || { echo "  Cancelled."; return; }

  # Place the order
  local -a curl_args=()
  curl_args+=(-d "product_id=$id")
  curl_args+=(-d "location=$location")
  for fp in "${_SELECTED_KEYS[@]}"; do
    curl_args+=(--data-urlencode "authorized_key[]=$fp")
  done

  echo ""
  echo -n "  Placing order... "
  local result
  result=$(api POST /order/server/transaction "${curl_args[@]}")

  local txn_id txn_status
  txn_id=$(echo "$result" | jq -r '.transaction.id')
  txn_status=$(echo "$result" | jq -r '.transaction.status')

  info "✓ Done!"
  echo ""
  echo -e "  ${BOLD}Order Placed${NC}"
  echo -e "  ${DIM}Transaction${NC}  $txn_id"
  echo -e "  ${DIM}Status${NC}       $txn_status"
  echo ""
  dim "  Track with: hrobot catalog show or check robot.hetzner.com"
  echo ""
}

# ─── vSwitch Commands ─────────────────────────────────────────────────

cmd_vswitch() {
  local action="${1:-list}"
  need_auth

  case "$action" in
    list)
      api GET /vswitch | fmt
      ;;
    get)
      local id="${2:-}" ; [ -n "$id" ] || die "Usage: hrobot vswitch get <id>"
      api GET "/vswitch/$id" | fmt
      ;;
    create)
      local name="${2:-}" vlan="${3:-}"
      [ -n "$name" ] && [ -n "$vlan" ] || die "Usage: hrobot vswitch create <name> <vlan-id>"
      api POST /vswitch -d "name=$name" -d "vlan=$vlan" | fmt
      info "✓ vSwitch '$name' created"
      ;;
    del)
      local id="${2:-}" ; [ -n "$id" ] || die "Usage: hrobot vswitch del <id>"
      api DELETE "/vswitch/$id" | fmt
      info "✓ vSwitch $id deleted"
      ;;
    *)
      die "Usage: hrobot vswitch [list|get|create|del] [args...]"
      ;;
  esac
}

# ─── Failover Commands ───────────────────────────────────────────────

cmd_failover() {
  local action="${1:-list}"
  need_auth

  case "$action" in
    list)
      api GET /failover | fmt
      ;;
    get)
      local ip="${2:-}" ; [ -n "$ip" ] || die "Usage: hrobot failover get <ip>"
      api GET "/failover/$ip" | fmt
      ;;
    switch)
      local ip="${2:-}" target="${3:-}"
      [ -n "$ip" ] && [ -n "$target" ] || die "Usage: hrobot failover switch <failover-ip> <target-server-ip>"
      api POST "/failover/$ip" -d "active_server_ip=$target" | fmt
      info "✓ Failover $ip routed to $target"
      ;;
    *)
      die "Usage: hrobot failover [list|get|switch] [args...]"
      ;;
  esac
}

# ─── Main ─────────────────────────────────────────────────────────────

usage() {
  local b d g bl n
  if [ -t 1 ]; then
    b=$'\033[1m' d=$'\033[2m' g=$'\033[0;32m' bl=$'\033[0;34m' n=$'\033[0m'
  else
    b="" d="" g="" bl="" n=""
  fi

  echo "${b}hrobot${n} — CLI for Hetzner Robot API (dedicated servers)"
  echo ""
  echo "  Usage: ${g}hr${n} ${bl}<command>${n} [args...]  ${d}(or: hrobot)${n}"
  echo ""
  echo "${b}AUTH${n}"
  echo "  ${g}auth${n}               Authenticate with Hetzner Robot API"
  echo "  ${g}status${n}             Check authentication and API connection"
  echo ""
  echo "${b}SERVERS${n} ${d}— alias: ${g}s${n}"
  echo "  ${g}servers${n}            List all servers"
  echo "  ${g}server${n} <num>       Show server details"
  echo "  ${g}rename${n} <num> <n>   Rename a server"
  echo "  ${g}reset${n} <num> [type] Reset server (sw|hw|man)"
  echo "  ${g}wol${n} <num>          Send Wake-on-LAN packet"
  echo "  ${g}cancel${n} <num>       Cancel a server ${d}(with confirmation)${n}"
  echo "  ${g}boot${n} <num>         Show boot configuration"
  echo "  ${g}rescue${n} <num> [..]  Manage rescue mode (status|activate|deactivate|last)"
  echo ""
  echo "${b}NETWORK${n}"
  echo "  ${g}ips${n}                List all IP addresses"
  echo "  ${g}ip${n} <addr>          Show IP details"
  echo "  ${g}subnets${n}            List all subnets"
  echo "  ${g}rdns${n} [action]      Manage reverse DNS (list|get|set|del)"
  echo "  ${g}firewall${n} <num>     Show/manage firewall (status|disable)"
  echo "  ${g}failover${n} [action]  Manage failover IPs (list|get|switch)"
  echo "  ${g}vswitch${n} [action]   Manage vSwitches (list|get|create|del)"
  echo "  ${g}traffic${n} <num> [p]  Show traffic stats (daily|monthly|yearly)"
  echo ""
  echo "${b}SSH KEYS${n}"
  echo "  ${g}keys${n}               List SSH keys"
  echo "  ${g}key${n} [action]       Manage keys (list|add|del)"
  echo ""
  echo "${b}STORAGE${n}"
  echo "  ${g}storageboxes${n}       List storage boxes"
  echo "  ${g}storagebox${n} <id>    Show storage box details"
  echo ""
  echo "${b}SERVER MARKET${n} ${d}(auction / refurbished) — alias: ${g}m${n}"
  echo "  ${g}market${n}             List auction servers ${d}(sorted by price)${n}"
  echo "  ${g}market show${n} <id>   Show server details"
  echo "  ${g}market buy${n} <id>    Order a server ${d}(with confirmation)${n}"
  echo "  ${g}market tx${n}          List market transactions"
  echo ""
  echo "  ${d}Filters:  --ram N  --price N  --dc X  --cpu X  --nvme  --ssd  --hdd  --ecc${n}"
  echo "  ${d}Sort:     --sort price|ram|disk|drop${n}"
  echo "  ${d}Example:  hr m --ram 64 --nvme --sort ram${n}"
  echo ""
  echo "${b}SERVER CATALOG${n} ${d}(new / standard) — alias: ${g}c${n}"
  echo "  ${g}catalog${n}            List dedicated servers with pricing"
  echo "  ${g}catalog show${n} <id>  Show server details, OS, locations"
  echo "  ${g}catalog buy${n} <id>   Order a server ${d}(with confirmation)${n}"
  echo ""
  echo "  ${d}Sort:     --sort price|ram|name${n}"
  echo ""
  echo "${b}OPTIONS${n}"
  echo "  ${g}-h${n}, ${g}--help${n}         Show this help"
  echo "  ${g}-v${n}, ${g}--version${n}      Show version"
  echo ""
  echo "${d}Config: \$HROBOT_CONFIG_DIR (default: ~/.config/hrobot)${n}"
}

main() {
  need_cmd curl
  need_cmd jq

  local cmd="${1:-help}"
  shift 2>/dev/null || true

  case "$cmd" in
    auth)           cmd_auth "$@" ;;
    status)         cmd_status "$@" ;;
    servers|ls|s)   cmd_servers "$@" ;;
    server)         cmd_server "$@" ;;
    rename)         cmd_server_rename "$@" ;;
    reset)          cmd_reset "$@" ;;
    rescue)         cmd_rescue "$@" ;;
    boot)           cmd_boot "$@" ;;
    wol)            cmd_wol "$@" ;;
    cancel)         cmd_cancel "$@" ;;
    ips)            cmd_ips "$@" ;;
    ip)             cmd_ip "$@" ;;
    subnets)        cmd_subnets "$@" ;;
    rdns)           cmd_rdns "$@" ;;
    firewall|fw|f)  cmd_firewall "$@" ;;
    failover|fo)    cmd_failover "$@" ;;
    vswitch|vs)     cmd_vswitch "$@" ;;
    traffic|t)      cmd_traffic "$@" ;;
    keys|k)         cmd_keys "$@" ;;
    key)            cmd_key "$@" ;;
    storageboxes)   cmd_storageboxes "$@" ;;
    storagebox)     cmd_storagebox "$@" ;;
    market|sb|m)    cmd_market "$@" ;;
    catalog|new|c)  cmd_catalog "$@" ;;
    -v|--version|version) echo "hrobot $VERSION" ;;
    -h|--help|help) usage ;;
    *)              die "Unknown command: $cmd. Run 'hrobot help' for usage." ;;
  esac
}

main "$@"
