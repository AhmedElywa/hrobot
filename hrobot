#!/usr/bin/env bash
# hrobot вЂ” CLI for Hetzner Robot API (dedicated servers)
# https://robot.hetzner.com/doc/webservice/en.html

set -euo pipefail

VERSION="1.0.0"
API_BASE="https://robot-ws.your-server.de"
CONFIG_DIR="${HROBOT_CONFIG_DIR:-$HOME/.config/hrobot}"
CONFIG_FILE="$CONFIG_DIR/credentials"

# в”Ђв”Ђв”Ђ Colors в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
BLUE='\033[0;34m'
BOLD='\033[1m'
DIM='\033[2m'
NC='\033[0m'

# в”Ђв”Ђв”Ђ Helpers в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
die()  { echo -e "${RED}error:${NC} $*" >&2; exit 1; }
info() { echo -e "${GREEN}$*${NC}"; }
warn() { echo -e "${YELLOW}$*${NC}"; }
dim()  { echo -e "${DIM}$*${NC}"; }

need_cmd() {
  command -v "$1" >/dev/null 2>&1 || die "'$1' is required but not installed"
}

need_auth() {
  [ -f "$CONFIG_FILE" ] || die "Not authenticated. Run: hrobot auth"
  source "$CONFIG_FILE"
  [ -n "${HROBOT_USER:-}" ] && [ -n "${HROBOT_PASS:-}" ] || die "Invalid credentials. Run: hrobot auth"
}

# API call helper
api() {
  local method="${1^^}"
  local endpoint="$2"
  shift 2
  local url="$API_BASE$endpoint"

  local response
  response=$(curl -s -w "\n%{http_code}" \
    -u "$HROBOT_USER:$HROBOT_PASS" \
    -X "$method" \
    -H "Accept: application/json" \
    "$@" \
    "$url" 2>&1) || die "Request failed: $url"

  local http_code body
  http_code=$(echo "$response" | tail -n1)
  body=$(echo "$response" | sed '$d')

  case "$http_code" in
    2[0-9][0-9]) echo "$body" ;;
    401)         die "Authentication failed (401). Check credentials with: hrobot auth" ;;
    403)         die "Forbidden (403). Your account may not have API access." ;;
    404)         die "Not found (404): $endpoint" ;;
    409)         die "Conflict (409): $(echo "$body" | jq -r '.error.message // "Resource conflict"')" ;;
    429)         die "Rate limited (429). Wait and retry." ;;
    *)           die "HTTP $http_code: $(echo "$body" | jq -r '.error.message // .' 2>/dev/null || echo "$body")" ;;
  esac
}

# Format JSON output вЂ” use jq if complex, raw if simple
fmt() {
  if [ -t 1 ]; then
    jq -C "${1:-.}" 2>/dev/null || cat
  else
    jq "${1:-.}" 2>/dev/null || cat
  fi
}

# Table formatter: takes jq expression that produces tab-separated lines
table() {
  local header="$1"
  local jq_expr="$2"
  echo -e "${BOLD}$header${NC}"
  jq -r "$jq_expr" 2>/dev/null | column -t -s $'\t' || cat
}

# в”Ђв”Ђв”Ђ Commands в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

cmd_auth() {
  echo -e "${BOLD}Hetzner Robot API Authentication${NC}"
  echo "Get your credentials at: https://robot.hetzner.com в†’ Settings в†’ Webservice"
  echo ""
  read -rp "Username (e.g. #ws+xxxxx): " user
  read -rsp "Password: " pass
  echo ""

  # Test credentials
  echo -n "Verifying... "
  local response
  response=$(curl -s -w "\n%{http_code}" -u "$user:$pass" "$API_BASE/server" 2>&1)
  local code
  code=$(echo "$response" | tail -n1)

  if [[ "$code" == 2* ]]; then
    mkdir -p "$CONFIG_DIR"
    chmod 700 "$CONFIG_DIR"
    cat > "$CONFIG_FILE" << EOF
HROBOT_USER="$user"
HROBOT_PASS="$pass"
EOF
    chmod 600 "$CONFIG_FILE"
    info "вњ“ Authenticated successfully. Credentials saved to $CONFIG_FILE"
  else
    die "Authentication failed (HTTP $code). Check your credentials."
  fi
}

cmd_status() {
  need_auth
  echo -e "${BOLD}Authentication${NC}"
  echo "  User: $HROBOT_USER"
  echo "  Config: $CONFIG_FILE"
  echo ""

  echo -n "API connection: "
  if api GET /server >/dev/null 2>&1; then
    info "вњ“ Connected"
  else
    die "Failed"
  fi
}

# в”Ђв”Ђв”Ђ Server Commands в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

cmd_servers() {
  need_auth
  api GET /server | table "SERVERS" \
    '.[] | .server | [.server_number, .server_name, .server_ip, .product, .dc, .status] | @tsv' |
    (echo -e "NUMBER\tNAME\tIP\tPRODUCT\tDC\tSTATUS" && cat) | column -t -s $'\t'
}

cmd_server() {
  local num="${1:-}" ; [ -n "$num" ] || die "Usage: hrobot server <server-number>"
  need_auth
  api GET "/server/$num" | jq '.server'
}

cmd_server_rename() {
  local num="${1:-}" name="${2:-}"
  [ -n "$num" ] && [ -n "$name" ] || die "Usage: hrobot rename <server-number> <new-name>"
  need_auth
  api POST "/server/$num" -d "server_name=$name" | jq '.server'
  info "вњ“ Server $num renamed to '$name'"
}

# в”Ђв”Ђв”Ђ Reset Commands в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

cmd_reset() {
  local num="${1:-}" type="${2:-sw}"
  [ -n "$num" ] || die "Usage: hrobot reset <server-number> [sw|hw|man]"
  need_auth

  case "$type" in
    sw)  type="sw"  ; desc="Software reset" ;;
    hw)  type="hw"  ; desc="Hardware reset (press reset button)" ;;
    man) type="man" ; desc="Manual reset (technician)" ;;
    *)   die "Reset type must be: sw, hw, or man" ;;
  esac

  warn "вљ  $desc on server $num"
  read -rp "Continue? [y/N] " confirm
  [[ "$confirm" =~ ^[Yy]$ ]] || { echo "Cancelled."; return; }

  api POST "/reset/$num" -d "type=$type" | fmt
  info "вњ“ Reset initiated"
}

# в”Ђв”Ђв”Ђ Rescue Commands в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

cmd_rescue() {
  local num="${1:-}" ; [ -n "$num" ] || die "Usage: hrobot rescue <server-number> [activate|deactivate|status]"
  local action="${2:-status}"
  need_auth

  case "$action" in
    status|info)
      api GET "/boot/$num/rescue" | fmt
      ;;
    activate|on)
      local os="${3:-linux}"
      api POST "/boot/$num/rescue" -d "os=$os" | fmt
      info "вњ“ Rescue mode activated. Reboot the server to enter rescue."
      ;;
    deactivate|off)
      api DELETE "/boot/$num/rescue" | fmt
      info "вњ“ Rescue mode deactivated"
      ;;
    last)
      api GET "/boot/$num/rescue/last" | fmt
      ;;
    *)
      die "Usage: hrobot rescue <server-number> [status|activate|deactivate|last]"
      ;;
  esac
}

